/**
 * жүӢзҺҜжүӢиЎЁзҙ§жҖҘе‘јеҸ«йЎөйқў
 * жҸҗдҫӣдёҖй”®зҙ§жҖҘе‘јеҸ«е’ҢжҖҘж•‘жҢҮеҚ—еҠҹиғҪ
 */
import { router } from '@kit.ArkUI';
import { call } from '@kit.TelephonyKit';
import { DeviceTypeUtil } from '../utils/DeviceTypeUtil';

interface EmergencyContact {
  id: string;
  name: string;
  phone: string;
  relation: string;
  icon: string;
}

@Entry
@Component
struct WatchEmergencyPage {
  @State isSOSActive: boolean = false;
  @State sosCountDown: number = 5;
  @State emergencyContacts: EmergencyContact[] = [];
  private deviceUtil: DeviceTypeUtil = DeviceTypeUtil.getInstance();
  private sosTimer: number = -1;

  aboutToAppear(): void {
    this.loadEmergencyContacts();
  }

  aboutToDisappear(): void {
    if (this.sosTimer !== -1) {
      clearInterval(this.sosTimer);
    }
  }

  loadEmergencyContacts(): void {
    // д»ҺAppStorageеҠ иҪҪзҙ§жҖҘиҒ”зі»дәә
    const stored = AppStorage.get<EmergencyContact[]>('emergencyContacts');
    if (stored && stored.length > 0) {
      this.emergencyContacts = stored;
    } else {
      // й»ҳи®Өзҙ§жҖҘиҒ”зі»дәә
      this.emergencyContacts = [
        { id: '1', name: 'жҖҘж•‘дёӯеҝғ', phone: '120', relation: 'жҖҘж•‘', icon: 'рҹҡ‘' },
        { id: '2', name: 'жҠҘиӯҰ', phone: '110', relation: 'жҠҘиӯҰ', icon: 'рҹҡ”' },
        { id: '3', name: 'е®¶дәә', phone: '13800138000', relation: 'е®¶дәә', icon: 'рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§' }
      ];
    }
  }

  startSOS(): void {
    this.isSOSActive = true;
    this.sosCountDown = 5;

    this.sosTimer = setInterval(() => {
      this.sosCountDown--;
      if (this.sosCountDown <= 0) {
        clearInterval(this.sosTimer);
        this.executeSOS();
      }
    }, 1000);
  }

  cancelSOS(): void {
    if (this.sosTimer !== -1) {
      clearInterval(this.sosTimer);
    }
    this.isSOSActive = false;
    this.sosCountDown = 5;
  }

  executeSOS(): void {
    // жү§иЎҢзҙ§жҖҘе‘јеҸ«
    this.isSOSActive = false;
    // е‘јеҸ«з¬¬дёҖдёӘзҙ§жҖҘиҒ”зі»дәәпјҲйҖҡеёёжҳҜжҖҘж•‘дёӯеҝғпјү
    if (this.emergencyContacts.length > 0) {
      this.makeCall(this.emergencyContacts[0].phone);
    }
  }

  makeCall(phoneNumber: string): void {
    // еҸ‘иө·з”өиҜқе‘јеҸ«
    call.makeCall(phoneNumber, (err) => {
      if (err) {
        console.error('[WatchEmergencyPage] е‘јеҸ«еӨұиҙҘ:', err.message);
      }
    });
  }

  build() {
    Column() {
      // йЎ¶йғЁж Үйўҳж Ҹ
      Row() {
        Text('вҶҗ')
          .fontSize(this.deviceUtil.getAdaptiveFontSize(20))
          .fontColor('#FFFFFF')
          .onClick(() => {
            router.back();
          })

        Text('зҙ§жҖҘе‘јеҸ«')
          .fontSize(this.deviceUtil.getAdaptiveFontSize(16))
          .fontColor('#FFFFFF')
          .fontWeight(FontWeight.Bold)
          .layoutWeight(1)
          .textAlign(TextAlign.Center)

        Text(' ')
          .fontSize(this.deviceUtil.getAdaptiveFontSize(20))
      }
      .width('100%')
      .height(this.deviceUtil.getAdaptiveSpacing(50))
      .padding({ left: 12, right: 12 })
      .linearGradient({
        angle: 135,
        colors: [['#E67E22', 0], ['#D35400', 1]]
      })

      // SOSжҢүй’®
      Column() {
        if (this.isSOSActive) {
          // еҖ’и®Ўж—¶зҠ¶жҖҒ
          Column() {
            Text('SOS')
              .fontSize(this.deviceUtil.getAdaptiveFontSize(36))
              .fontColor('#FFFFFF')
              .fontWeight(FontWeight.Bold)

            Text(`${this.sosCountDown}з§’еҗҺе‘јеҸ«`)
              .fontSize(this.deviceUtil.getAdaptiveFontSize(14))
              .fontColor('#FFFFFF')
              .margin({ top: 8 })

            Button('еҸ–ж¶Ҳ')
              .width('60%')
              .height(this.deviceUtil.getAdaptiveButtonHeight(36))
              .backgroundColor('#FFFFFF')
              .fontColor('#E67E22')
              .margin({ top: 16 })
              .onClick(() => {
                this.cancelSOS();
              })
          }
          .width('100%')
          .height('100%')
          .justifyContent(FlexAlign.Center)
        } else {
          // жӯЈеёёзҠ¶жҖҒ
          Column() {
            Text('рҹҶҳ')
              .fontSize(this.deviceUtil.getAdaptiveFontSize(48))

            Text('SOS')
              .fontSize(this.deviceUtil.getAdaptiveFontSize(24))
              .fontColor('#FFFFFF')
              .fontWeight(FontWeight.Bold)
              .margin({ top: 8 })

            Text('й•ҝжҢүзҙ§жҖҘе‘јеҸ«')
              .fontSize(this.deviceUtil.getAdaptiveFontSize(12))
              .fontColor('#FFFFFF')
              .opacity(0.8)
              .margin({ top: 4 })
          }
          .width('100%')
          .height('100%')
          .justifyContent(FlexAlign.Center)
          .gesture(
            LongPressGesture({ repeat: false })
              .onAction(() => {
                this.startSOS();
              })
          )
        }
      }
      .width('80%')
      .height(this.deviceUtil.getAdaptiveSpacing(150))
      .margin({ top: this.deviceUtil.getAdaptiveSpacing(20) })
      .linearGradient({
        angle: 135,
        colors: [['#E74C3C', 0], ['#C0392B', 1]]
      })
      .borderRadius(this.deviceUtil.getAdaptiveSpacing(75))
      .shadow({
        radius: 8,
        color: 'rgba(231, 76, 60, 0.4)',
        offsetX: 0,
        offsetY: 4
      })

      // зҙ§жҖҘиҒ”зі»дәәеҲ—иЎЁ
      Column() {
        Text('зҙ§жҖҘиҒ”зі»дәә')
          .fontSize(this.deviceUtil.getAdaptiveFontSize(14))
          .fontColor('#666666')
          .margin({ bottom: this.deviceUtil.getAdaptiveSpacing(8) })

        ForEach(this.emergencyContacts, (contact: EmergencyContact) => {
          this.buildContactItem(contact)
        }, (contact: EmergencyContact) => contact.id)
      }
      .width('95%')
      .margin({ top: this.deviceUtil.getAdaptiveSpacing(20) })
    }
    .width('100%')
    .height('100%')
    .backgroundColor('#F5F5F5')
  }

  @Builder buildContactItem(contact: EmergencyContact) {
    Row() {
      Text(contact.icon)
        .fontSize(this.deviceUtil.getAdaptiveFontSize(20))

      Column() {
        Text(contact.name)
          .fontSize(this.deviceUtil.getAdaptiveFontSize(14))
          .fontColor('#333333')
          .fontWeight(FontWeight.Bold)

        Text(contact.phone)
          .fontSize(this.deviceUtil.getAdaptiveFontSize(11))
          .fontColor('#999999')
          .margin({ top: 2 })
      }
      .layoutWeight(1)
      .alignItems(HorizontalAlign.Start)
      .margin({ left: 8 })

      Text('рҹ“һ')
        .fontSize(this.deviceUtil.getAdaptiveFontSize(20))
    }
    .width('100%')
    .padding(this.deviceUtil.getAdaptiveSpacing(12))
    .backgroundColor('#FFFFFF')
    .borderRadius(this.deviceUtil.getAdaptiveSpacing(10))
    .margin({ bottom: this.deviceUtil.getAdaptiveSpacing(8) })
    .onClick(() => {
      this.makeCall(contact.phone);
    })
  }
}
