        WHEN COUNT(mr.id) > 0 THEN '✅ 有病例数据'
        ELSE '❌ 无病例数据'
    END AS 验证结果
FROM user u
LEFT JOIN medical_record mr ON u.id = mr.user_id AND mr.is_deleted = 0
WHERE u.user_type = 0 AND u.is_deleted = 0
