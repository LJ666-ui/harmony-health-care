    fm.id AS 家属ID,
    fm.name AS 家属姓名,
    fm.relation AS 关系,
    fm.user_id AS 关联用户ID,
    u.username AS 患者用户名,
    u.phone AS 患者手机号,
    u.age AS 患者年龄,
    CASE 
        WHEN u.user_type = 0 THEN '✅ 正确：关联患者'
        WHEN u.user_type = 1 THEN '❌ 错误：关联医生'
        ELSE '⚠️ 其他类型'
    END AS 验证结果
FROM family_member fm
LEFT JOIN user u ON fm.user_id = u.id
WHERE fm.is_deleted = 0;

